#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BACKEND_CLI="${BARRY_VIDEO_BACKEND:-$HOME/inbeidou_cli.py}"
PYTHON_BIN="${BARRY_VIDEO_PYTHON:-python3}"

usage() {
  cat <<'EOF'
Usage:
  barry-video install
  barry-video backend <inbeidou_cli.py args...>
  barry-video package [output.tgz]
  barry-video smoke
EOF
}

COMMAND="${1:-}"

case "$COMMAND" in
  install)
    shift
    exec "$ROOT_DIR/scripts/install-local.sh" "$@"
    ;;
  backend)
    shift
    exec "$PYTHON_BIN" "$BACKEND_CLI" "$@"
    ;;
  package)
    shift
    exec "$ROOT_DIR/scripts/package-release.sh" "$@"
    ;;
  smoke)
    shift
    exec "$ROOT_DIR/scripts/smoke-test.sh" "$@"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
