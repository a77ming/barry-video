#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  BIN_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$BIN_DIR/$SOURCE"
done
BIN_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
ROOT_DIR="$(cd "$BIN_DIR/.." && pwd)"
PRIVATE_BACKEND="$ROOT_DIR/backend/inbeidou_cli.py"
BACKEND_CLI="${BARRY_VIDEO_BACKEND:-$PRIVATE_BACKEND}"
if [ ! -f "$BACKEND_CLI" ]; then
  if [ -f "$HOME/inbeidou_cli.py" ]; then
    BACKEND_CLI="$HOME/inbeidou_cli.py"
  elif [ -f "/Users/ming/inbeidou_cli.py" ]; then
    BACKEND_CLI="/Users/ming/inbeidou_cli.py"
  fi
fi
PYTHON_BIN="${BARRY_VIDEO_PYTHON:-python3}"

usage() {
  cat <<'EOF'
Usage:
  barry-video install
  barry-video backend <inbeidou_cli.py args...>
  barry-video package [output.tgz]
  barry-video smoke
EOF
}

COMMAND="${1:-}"

case "$COMMAND" in
  install)
    shift
    exec "$ROOT_DIR/scripts/install-local.sh" "$@"
    ;;
  backend)
    shift
    exec "$PYTHON_BIN" "$BACKEND_CLI" "$@"
    ;;
  package)
    shift
    exec "$ROOT_DIR/scripts/package-release.sh" "$@"
    ;;
  smoke)
    shift
    exec "$ROOT_DIR/scripts/smoke-test.sh" "$@"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
